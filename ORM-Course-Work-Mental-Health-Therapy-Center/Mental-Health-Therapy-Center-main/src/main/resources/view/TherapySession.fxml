<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f8fafc;" stylesheets="@../style/global.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.therapycenter.controller.TherapySessionController">
    <children>
        <VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <!-- Header -->
                <Label text="Therapy Session Scheduling" textFill="#0f766e">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <padding>
                        <Insets bottom="5.0" />
                    </padding>
                    <graphic>
                        <HBox prefHeight="4.0" prefWidth="80.0" style="-fx-background-color: #0d9488; -fx-background-radius: 2px;" />
                    </graphic>
                </Label>

                <!-- Session Scheduling Form -->
                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Session ID:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblSessionId" text="Automatic" textFill="#1e293b">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Date:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <DatePicker fx:id="datePickerSession" prefHeight="30.0" prefWidth="220.0" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Time:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <ChoiceBox fx:id="selectTime" prefHeight="30.0" prefWidth="220.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Patient:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <ChoiceBox fx:id="selectPatient" prefHeight="30.0" prefWidth="220.0" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Therapist:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <ChoiceBox fx:id="selectTherapist" prefHeight="30.0" prefWidth="220.0" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefWidth="90.0" text="Program:" textFill="#475569">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <ChoiceBox fx:id="selectProgram" prefHeight="30.0" prefWidth="220.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0" />

                <!-- Buttons -->
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label fx:id="errorMessage" prefHeight="17.0" prefWidth="112.0" textFill="#e11d48" />
                        <Button fx:id="btnSchedule" mnemonicParsing="false" onAction="#scheduleSession" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold;" text="Schedule">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#updateSession" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #d97706; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold;" text="Update">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#cancelSession" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e11d48; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold;" text="Cancel">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnReset" mnemonicParsing="false" onAction="#resetForm" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold;" text="Reset">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>

                <!-- Session Records Header -->
                <Label text="Therapy Session Records:" textFill="#1e293b">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>

                <!-- Session Records Table -->
                <TableView fx:id="tblTherapySessions" onMouseClicked="#sessionSelectOnAction" prefHeight="290.0" prefWidth="740.0" stylesheets="@../style/table.css" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSessionId" prefWidth="88.48700082302094" text="Session ID" />
                        <TableColumn fx:id="colDate" prefWidth="90.99134063720703" text="Date" />
                        <TableColumn fx:id="colTime" prefWidth="80.97392272949219" text="Time" />
                        <TableColumn fx:id="colPatient" prefWidth="120.0" text="Patient" />
                        <TableColumn fx:id="colTherapist" prefWidth="120.0" text="Therapist" />
                        <TableColumn fx:id="colProgram" prefWidth="160.0" text="Program" />
                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="Status" />
                    </columns>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
